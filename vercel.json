{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-(.*).xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "pawdee.vercel.app" }],
      "destination": "https://www.pawdeepet.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap-places.xml", "destination": "/api/sitemap-places" },
    { "source": "/place/:id", "destination": "/place.html?id=:id" },
    { "source": "/__/auth/:path*", "destination": "https://pawdee-f082e.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/:path*", "destination": "https://pawdee-f082e.firebaseapp.com/__/firebase/:path*" }
  ]
}
